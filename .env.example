# Auth
SECRET_KEY=change-me-in-production
SEED_CATALOG=1

# SQLite (dev local — défaut: instance/mvpforge.db)
# DATABASE_URL=sqlite:///instance/mvpforge.db

# ── Supabase Postgres (production Scalingo) ──────────────────────────────────
# Dashboard Supabase → Project Settings → Database → Connection string (URI)
# Pooler recommandé sur Scalingo (port 6543) :
# DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ── Supabase Auth (optionnel — sinon AUTH_BACKEND=local) ─────────────────────
# AUTH_BACKEND=supabase
# SUPABASE_URL=https://<PROJECT_REF>.supabase.co
# SUPABASE_KEY=<anon-or-service-role-key>

# ── Supabase Storage (persistance des images — production) ───────────────────
# Actif dès que SUPABASE_URL + SUPABASE_SERVICE_KEY sont définis.
# SUPABASE_SERVICE_KEY=<service-role-key>
# SUPABASE_STORAGE_BUCKET=mvp-images

# ── Stripe (paiements annonces + achats MVP + Connect vendeurs) ──────────────
# La même STRIPE_SECRET_KEY sert au Checkout et à Stripe Connect (reversements).
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=

# ── E-mails transactionnels (SMTP — vendeur/acheteur) ────────────────────────
# Inactifs tant que non configurés (les envois sont simplement loggués).
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=MVPForge <no-reply@mvpforge.io>

# ── Chiffrement du dossier de passation ──────────────────────────────────────
# Par défaut dérivé de SECRET_KEY. Définir une clé dédiée si besoin (⚠️ changer
# cette clé rend illisibles les secrets déjà stockés).
# HANDOVER_KEY=
